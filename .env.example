# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=cloud_pricing
POSTGRES_PASSWORD=cloud_pricing
POSTGRES_DB=cloud_pricing

# ── Ports exposed on the host ──────────────────────────────────────────────────
# Change these if the defaults conflict with something already running locally.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# This URL is baked into the frontend image at build time.
# It must be reachable from the user's *browser*, not from inside Docker.
# Keep it as localhost:<BACKEND_PORT> for a local setup.
NEXT_PUBLIC_API_URL=http://localhost:8000
